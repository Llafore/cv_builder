<div class="college">
    <div class="row">
        <strong>{{college_name}} - {{course}}</strong>
        <strong>{{start_date}} - {{end_date}}</strong>
    </div>

    <p>Percentual de rendimento: {{avarage_grade}}</p>

    <div class="columns">
        <ul>
            {{#each bulletsSplit.left}}
            <li>{{this}}</li>
            {{/each}}
        </ul>
        <ul>
            {{#each bulletsSplit.right}}
            <li>{{this}}</li>
            {{/each}}
        </ul>
    </div>
</div>